#!/usr/bin/env python3
import os
import sys
import time
import argparse
import logging
import traceback
import subprocess
from pathlib import Path
from functools import partial
from concurrent.futures import ProcessPoolExecutor, as_completed
from tqdm import tqdm

# Setup a dedicated failure logger for tracking errors cleanly
failure_logger = logging.getLogger("failures")
failure_logger.setLevel(logging.ERROR)
handler = logging.FileHandler("failures.log", mode="a")
handler.setFormatter(logging.Formatter("%(asctime)s - %(message)s"))
failure_logger.addHandler(handler)

def process_file(tgz_path_str, obs, nfs1_base, vast_base, force=False, verbose=False):
    """
    Decompresses a .tgz file to a specific NFS directory,
    then compresses it to .tar.zstd (level 12) in a specific VAST directory.
    Preserves original input timestamps and prints inner steps if verbose=True.
    """
    tgz_path = Path(tgz_path_str)
    stem = tgz_path.stem  # e.g., '61203_lvm_agcam'
    
    if '_' in stem:
        _, prefix = stem.split('_', 1)
    else:
        prefix = stem

    # Define the output directory paths
    tar_dir = Path(nfs1_base) / "transfer" / "hpss" / "staging" / obs / prefix
    zstd_dir = Path(vast_base) / "transfer" / "cloud" / "staging" / obs / prefix

    # Ensure staging directories exist
    tar_dir.mkdir(parents=True, exist_ok=True)
    zstd_dir.mkdir(parents=True, exist_ok=True)

    # Define final file targets
    tar_path = tar_dir / f"{stem}.tar"
    zstd_path = zstd_dir / f"{stem}.tar.zstd"

    # Pre-check existence if force is False
    if not force:
        if tar_path.exists() and zstd_path.exists():
            if verbose:
                tqdm.write(f"[{stem}] SKIPPED: Both target files already exist.")
            return "SKIPPED"

    try:
        # Capture the original file's access and modification timestamps
        stat_info = tgz_path.stat()
        orig_timestamps = (stat_info.st_atime, stat_info.st_mtime)

        # 1. Extract .tgz to .tar to the NFS1 staging path
        if verbose:
            tqdm.write(f"[{stem}] Decompressing source .tgz archive to {tar_path}...")
        
        with open(tar_path, 'wb') as tar_out:
            subprocess.run(['gzip', '-d', '-c', str(tgz_path)], stdout=tar_out, check=True)
        
        # Apply original timestamp to the .tar file
        os.utime(tar_path, orig_timestamps)
        
        # 2. Compress .tar to .tar.zstd using compression level 12
        if verbose:
            tqdm.write(f"[{stem}] Compressing .tar archive to level-12 .zstd at {zstd_path}...")
            
        zstd_cmd = ['zstd', '-q', '-12', '-T1', str(tar_path), '-o', str(zstd_path)]
        if force:
            zstd_cmd.insert(2, '-f')
            
        subprocess.run(zstd_cmd, check=True)
        
        # Apply original timestamp to the .tar.zstd file
        os.utime(zstd_path, orig_timestamps)
        
        if verbose:
            tqdm.write(f"[{stem}] SUCCESS: Extracted, compressed, and timestamps synchronized.")
            
        return "SUCCESS"
    
    except Exception as e:
        # Capture error and write to the dedicated failures.log file
        error_msg = f"ERROR processing {tgz_path_str}: {str(e)}\n{traceback.format_exc()}"
        failure_logger.error(error_msg)
        return f"FAILURE: {stem}"

def main():
    parser = argparse.ArgumentParser(description="Parallel Tar/Zstd generator for SDSS mirror backups.")
    parser.add_argument('-m', '--mjd', type=int, help="Specific MJD to process")
