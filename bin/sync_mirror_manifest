#!/usr/bin/env python3
from transfer import Mirror, Argument
arg = Argument('transfer_mirror')
options = arg.options

def sync_mirror(options = None):
    mirror = Mirror(options=options)
    if mirror.ready:
        mirror.set_item_from_manifest()
        if mirror.item:
            mirror.sync_timestamps()
            mirror.write_file()
            mirror.done()
        else:
            if options.mjd: print("SYNC MJD %r> SKIP" % options.mjd)
            else: print("SYNC> SKIP" )
    else:
        if options.mjd: print("SYNC MJD %r> Not ready!" % options.mjd)
        else: print("SYNC> Not ready!")

if options.mjdlist:
    for options.mjd in options.mjdlist: sync_mirror(options = options)
else: sync_mirror(options = options)
