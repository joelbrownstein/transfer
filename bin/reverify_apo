#!/usr/bin/env python3
from transfer import Reverify, Argument

arg = Argument('reverify')
options = arg.options
options.observatory = observatory = 'apo'
options.ini_mode = mode = 'mos'
options.log_dir = 'reverify/%s' % mode
reverify = Reverify(options = options)
reverify.set_config()
reverify.set_logging()
if reverify.logging.ready:
    program = "%s_%s" % (arg.program, mode)
    reverify.set_history()
    reverify.set_process(program=program)
    if reverify.process.ready:
        reverify.set_sections()
        reverify.set_summary(mode = mode)
        reverify.run_verify()
        reverify.done()
    else:
        reverify.process.logger.critical("Detected another %s %s data reverify job running. Done!" % (observatory.upper(), mode.upper()))
        print("REVERIFY> System in use!")
else: print("REVERIFY> Logging not ready!")
