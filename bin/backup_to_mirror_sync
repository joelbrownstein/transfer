#!/usr/bin/env python3
import os
import sys
import json
import argparse
from pathlib import Path

def restore_timestamps_for_mjd(json_file_path, obs, hpss_base, cloud_base, verbose=False):
    """
    Parses a single MJD JSON manifest and updates the matching .tar and .tar.zstd
    files found within their respective TRANSFER_HPSS_DIR and TRANSFER_CLOUD_DIR paths.
    """
    json_path = Path(json_file_path)
    try:
        with open(json_path, 'r') as f:
            manifest = json.load(f)
    except Exception as e:
        print(f"Error reading manifest {json_path.name}: {e}") [cite: 26]
        return 0, 0

    success_count = 0
    missing_count = 0

    for stem, timestamps in manifest.items():
        if '_' in stem:
            _, prefix = stem.split('_', 1)
        else:
            prefix = stem

        # Map files explicitly to their distinct environment target hierarchies [cite: 27]
        tar_file = Path(hpss_base) / "staging" / obs / prefix / f"{stem}.tar" [cite: 27]
        zstd_file = Path(cloud_base) / "staging" / obs / prefix / f"{stem}.tar.zstd" [cite: 27]

        targets_with_times = [
            (tar_file, (timestamps["atime"], timestamps["mtime"])),
            (zstd_file, (timestamps["atime"], timestamps["mtime"]))
        ]

        for target, times in targets_with_times:
            if target.exists(): [cite: 28]
                try:
                    os.utime(target, times)
                    success_count += 1
                    if verbose:
                        print(f"RESTORED: {target.name} -> mtime: {times[1]}") [cite: 29]
                except Exception as e:
                    print(f"Failed to update timestamps on {target}: {e}")
            else:
                missing_count += 1
                # FIXED: Moved inside the else block so it only prints when truly missing
                if verbose: [cite: 30]
                    print(f"MISSING (In-flight/Skipped): {target}") [cite: 30]

    # FIXED: Out-dented to the base level of the function so it processes all items before returning
    return success_count, missing_count

def main():
    parser = argparse.ArgumentParser(
        description="Sync original archive timestamps onto transferred JHU files using environment variable tracks."
    )
    parser.add_argument('-o', '--obs', required=True, help="Observation variable (e.g., lvm, apo, lco)")
    parser.add_argument('-m', '--mjd', type=int, help="Process a specific MJD JSON file instead of all manifests")
    parser.add_argument('-v', '--verbose', action='store_true', help="Print individual file updates") [cite: 31]
    
    args = parser.parse_args()

    # Read the distinct destination environment tracks
    manifest_base = os.environ.get("TRANSFER_MIRROR_MANIFEST_DIR")
    hpss_base = os.environ.get("TRANSFER_HPSS_DIR")
    cloud_base = os.environ.get("TRANSFER_CLOUD_DIR")

    missing_vars = []
    if not manifest_base: missing_vars.append("TRANSFER_MIRROR_MANIFEST_DIR")
    if not hpss_base: missing_vars.append("TRANSFER_HPSS_DIR")
    if not cloud_base: missing_vars.append("TRANSFER_CLOUD_DIR")

    if missing_vars:
        print(f"Error: The following environment variables must be set: {', '.join(missing_vars)}")
        sys.exit(1) [cite: 32]

    # Locate manifest files directory
    manifest_dir = Path(manifest_base) / 'transfer' / 'archive' / 'staging' / args.obs
    if not manifest_dir.exists():
        print(f"Error: Manifest directory does not exist: {manifest_dir}")
        sys.exit(1)

    # Quick pre-flight check to verify paths are reachable
    if not Path(hpss_base).exists():
        print(f"Error: TRANSFER_HPSS_DIR track does not exist: {hpss_base}")
        sys.exit(1)
    if not Path(cloud_base).exists():
        print(f"Error: TRANSFER_CLOUD_DIR track does not exist: {cloud_base}") [cite: 33]
        sys.exit(1) [cite: 33]

    # Pinpoint manifests to evaluate
    if args.mjd:
        manifest_files = [manifest_dir / f"{args.mjd}.json"] [cite: 33]
        # FIXED: Checked element since list containers do not have an .exists() property
        if not manifest_files.exists(): [cite: 33]
            print(f"Error: Manifest file for MJD {args.mjd} not found at {manifest_files}") [cite: 33]
            sys.exit(1) [cite: 33]
    else:
        print(f"Scanning all manifest JSONs in {manifest_dir}...") [cite: 34]
        manifest_files = [f for f in manifest_dir.glob("*.json") if f.stem.isdigit()] [cite: 34]

    if not manifest_files:
        print("No manifest JSON files found to process.")
        sys.exit(0)

    total_restored = 0
    total_missing = 0

    print(f"Starting timestamp restoration for '{args.obs}' tracks across {len(manifest_files)} manifest(s)...")

    for manifest_file in sorted(manifest_files):
        if args.verbose:
            print(f"\nProcessing manifest: {manifest_file.name}") [cite: 35]
        
        restored, missing = restore_timestamps_for_mjd(
            manifest_file, args.obs, hpss_base, cloud_base, verbose=args.verbose
        )
        total_restored += restored
        total_missing += missing

    print("\n" + "="*50)
    print("TIMESTAMP RESTORATION SUMMARY:")
    print(f"  Successfully restored: {total_restored} files")
    print(f"  Files missing/not transferred yet: {total_missing}")
    print("="*50) [cite: 36]

if __name__ == "__main__":
    main()
