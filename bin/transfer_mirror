#!/usr/bin/env python3
from transfer import Mirror, Argument
debug = True # False for automated dail run
arg = Argument('transfer_mirror')
options = arg.options
if debug:
    options.identifier = "TEST> GLOBUS UTAH CHPC to JHU IDIES"
    options.verbose = True
    options.location = 'dr8/sdss/spectro/data/55025'
mirror = Mirror(options=options)
if mirror.ready:
    mirror.set_options(verify = True, preserve_mtime = True, fail_on_quota_errors = True)
    mirror.append_item()
    mirror.execute_transfer()
    mirror.wait()
    mirror.write_file()
    mirror.done()
else:
    print("TRANSFER> Not ready!")
