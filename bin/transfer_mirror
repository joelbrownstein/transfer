#!/usr/bin/env python3
from transfer import Mirror, Argument
arg = Argument('transfer_mirror')
options = arg.options

def transfer_mirror(options = None):
    mirror = Mirror(options=options)
    mirror.set_options(verify = True, preserve_mtime = True, fail_on_quota_errors = True)
    if mirror.ready:
        mirror.append_item()
        mirror.execute_transfer()
        if mirror.transfer:
            mirror.wait()
            mirror.write_file()
            mirror.done()
        else:
            if options.mjd: print("TRANSFER MJD %r> SKIP" % options.mjd)
            else: print("TRANSFER> SKIP" )
    else:
        if options.mjd: print("TRANSFER MJD %r> Not ready!" % options.mjd)
        else: print("TRANSFER> Not ready!")

if options.mjdlist:
    for options.mjd in options.mjdlist: transfer_mirror(options = options)
else: transfer_mirror(options = options)
